# ──────────────────────────────────────────────────
# 해외매크로 대시보드 — 환경 변수 예시
# 이 파일을 .env.local 로 복사한 후 실제 키를 입력하세요.
# .env.local 은 .gitignore 처리됨 (절대 커밋 금지)
# ──────────────────────────────────────────────────

# FRED API 키 (무료 발급: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# 한국은행 ECOS API 키 (무료 발급: https://ecos.bok.or.kr/api/)
BOK_API_KEY=your_bok_api_key_here

# Yahoo Finance는 키 없이 사용 가능 (별도 설정 불필요)
